# =============================================================================
# WhatsApp AI Triage Engine — environment variables
# =============================================================================
# Copy this file to `.env` (gitignored) and fill in real values.
#
# DEMO MODE
# ---------
# Set # Server-side flag — gates the data layer, server actions, auth checks.
DEMO_MODE=true
# Client-side flag — same value; gates the realtime simulator + UI banner.
NEXT_PUBLIC_DEMO_MODE=true
# Optional label shown in the topbar pill (defaults to "Demo").
NEXT_PUBLIC_ENV_LABEL=Demo to run the dashboard against in-memory fixtures with no
# external dependencies. Auth is bypassed, server actions log instead of
# calling n8n, and a small "realtime simulator" drips fake events on a timer.
# Perfect for `docker compose up` first-look.
DEMO_MODE=true

# =============================================================================
# Real-mode variables (ignored when DEMO_MODE=true)
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Create a project at https://supabase.com, then grab these from
# Project Settings -> API.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Twilio (WhatsApp Business) ----------------------------------------------
# WhatsApp sandbox docs: https://www.twilio.com/docs/whatsapp/sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# E.164 format with the `whatsapp:` prefix.
TWILIO_WHATSAPP_FROM=whatsapp:+15550100000

# --- n8n orchestration -------------------------------------------------------
# Import workflows from ./workflows/ into your n8n instance, then point these
# at the resulting production webhook URLs.
N8N_BASE_URL=https://n8n.example.com
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/twilio/incoming-whatsapp
N8N_OUTBOUND_WEBHOOK_URL=https://n8n.example.com/webhook/twilio/send-whatsapp-reply
N8N_STATUS_WEBHOOK_URL=https://n8n.example.com/webhook/twilio/message-status
N8N_API_KEY=

# --- OpenAI (used inside n8n for intent classification) ----------------------
OPENAI_API_KEY=
